import java.util.Scanner;
import java.util.Arrays;

class Edge implements Comparable<Edge> {
    int src, dest, weight;

    public int compareTo(Edge e) {
        return this.weight - e.weight;
    }
}

public class KruskalAlgorithm {
    static int[] parent;

    static int find(int i) {
        while (parent[i] != i) {
            i = parent[i];
        }
        return i;
    }

    static void union(int a, int b) {
        int rootA = find(a);
        int rootB = find(b);
        parent[rootA] = rootB;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of vertices: ");
        int v = sc.nextInt();

        System.out.print("Enter number of edges: ");
        int e = sc.nextInt();

        Edge[] edges = new Edge[e];

        for (int i = 0; i < e; i++) {
            edges[i] = new Edge();
            System.out.println("Enter source, destination and weight:");
            edges[i].src = sc.nextInt();
            edges[i].dest = sc.nextInt();
            edges[i].weight = sc.nextInt();
        }

        Arrays.sort(edges);

        parent = new int[v];
        for (int i = 0; i < v; i++) {
            parent[i] = i;
        }

        int count = 0;
        int totalCost = 0;

        System.out.println("Edges in Minimum Spanning Tree:");

        for (int i = 0; count < v - 1 && i < e; i++) {
            int a = find(edges[i].src);
            int b = find(edges[i].dest);

            if (a != b) {
                System.out.println(edges[i].src + " - " + edges[i].dest + " : " + edges[i].weight);
                totalCost += edges[i].weight;
                union(a, b);
                count++;
            }
        }

        System.out.println("Total Cost: " + totalCost);
    }
}
